{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup|resume",
				"hooks": [
					{
						"type": "command",
						"command": "~/.codex/hooks/session-start.sh",
						"timeout": 20,
						"statusMessage": "Starting local coding helpers..."
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "~/.codex/hooks/block-no-verify.sh",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "rtk hook claude",
						"timeout": 5
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "apply_patch",
				"hooks": [
					{
						"type": "command",
						"command": "~/.codex/hooks/post-turn-validate.sh",
						"timeout": 120,
						"statusMessage": "Running post-turn validation..."
					}
				]
			}
		],
		"SessionStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.codex/hooks/session-stop.sh",
						"timeout": 10,
						"statusMessage": "Stopping grepai watcher..."
					}
				]
			}
		]
	}
}
