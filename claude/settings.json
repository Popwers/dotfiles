{
	"permissions": {
		"defaultMode": "default",
		"allow": [
			"Read",
			"Edit",
			"Write",
			"Glob",
			"Grep",
			"Bash(*)",
			"mcp__claude_ai_Context7",
			"mcp__claude_ai_Figma",
			"mcp__claude_ai_Linear",
			"mcp__gh_grep",
			"mcp__exa"
		],
		"deny": [
			"Bash(rm -rf:*)",
			"Bash(rm -r :*)",
			"Bash(rm -f :*)",
			"Bash(sudo:*)",
			"Bash(su :*)",
			"Bash(doas :*)",
			"Bash(chmod 777:*)",
			"Bash(git push --force:*)",
			"Bash(git push -f:*)",
			"Bash(git push --force-with-lease:*)",
			"Bash(git reset --hard:*)",
			"Bash(curl * | sh:*)",
			"Bash(curl * | bash:*)",
			"Bash(curl * | fish:*)",
			"Bash(curl * | zsh:*)",
			"Bash(wget * | sh:*)",
			"Bash(wget * | bash:*)",
			"Bash(wget * | fish:*)"
		]
	},
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"enableAllProjectMcpServers": true,
	"statusLine": {
		"type": "command",
		"command": "~/.claude/statusline.sh",
		"padding": 0
	},
	"autoConnectIde": true,
	"env": {
		"CLAUDE_CODE_AUTO_COMPACT_WINDOW": "280000",
		"CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
		"DISABLE_TELEMETRY": "1",
		"DISABLE_ERROR_REPORTING": "1",
		"CLAUDE_ENABLE_STREAM_WATCHDOG": "1",
		"CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
		"CLAUDE_CODE_DISABLE_FAST_MODE": "1",
		"ENABLE_TOOL_SEARCH": "1",
		"CLAUDE_CODE_SLIM_SUBAGENT_CLAUDEMD": "1",
		"CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
	},
	"effortLevel": "high",
	"autoMemory": false,
	"showThinkingSummaries": true,
	"feedbackSurveyRate": 0,
	"autoUpdatesChannel": "latest",
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "pgrep -x ollama > /dev/null || nohup ollama serve > /dev/null 2>&1 &",
						"timeout": 10,
						"statusMessage": "Starting ollama..."
					},
					{
						"type": "command",
						"command": "command -v grepai >/dev/null 2>&1 && { grepai status >/dev/null 2>&1 || grepai init --yes >/dev/null 2>&1; grep -qsx '.grepai/' .gitignore 2>/dev/null || echo '.grepai/' >> .gitignore; grepai watch --background >/dev/null 2>&1; }; exit 0",
						"timeout": 20,
						"statusMessage": "Starting grepai..."
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/ensure-claudeignore.sh",
						"timeout": 5,
						"statusMessage": "Ensuring .claudeignore..."
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/block-no-verify.sh",
						"timeout": 5
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/auto-format.sh",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/typecheck.sh",
						"timeout": 30
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/run-tests.sh",
						"timeout": 30
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/check-console-log.sh",
						"timeout": 5
					},
					{
						"type": "command",
						"command": "command -v grepai >/dev/null 2>&1 && grepai watch --stop >/dev/null 2>&1; exit 0",
						"timeout": 10,
						"statusMessage": "Stopping grepai watcher..."
					}
				]
			}
		]
	}
}
