{
	"enabledPlugins": {
		"chrome-devtools-mcp@claude-plugins-official": true,
		"security-guidance@claude-plugins-official": true
	},
	"permissions": {
		"defaultMode": "default",
		"allow": [
			"Read",
			"Edit",
			"Write",
			"Glob",
			"Grep",
			"Bash(*)",
			"mcp__context7",
			"mcp__claude_ai_Figma",
			"mcp__claude_ai_Linear",
			"mcp__gh_grep",
			"mcp__serena",
			"mcp__claude_ai_Exa",
			"mcp__plugin_chrome-devtools-mcp_chrome-devtools"
		],
		"deny": [
			"Bash(sudo:*)",
			"Bash(su :*)",
			"Bash(doas :*)",
			"Bash(chmod 777:*)",
			"Bash(git push --force:*)",
			"Bash(git push -f:*)",
			"Bash(git push --force-with-lease:*)",
			"Bash(git reset --hard:*)",
			"Bash(curl * | sh:*)",
			"Bash(curl * | bash:*)",
			"Bash(curl * | fish:*)",
			"Bash(curl * | zsh:*)",
			"Bash(wget * | sh:*)",
			"Bash(wget * | bash:*)",
			"Bash(wget * | fish:*)"
		]
	},
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"enableAllProjectMcpServers": true,
	"statusLine": {
		"type": "command",
		"command": "~/.claude/statusline.sh",
		"padding": 0
	},
	"autoConnectIde": true,
	"model": "claude-fable-5",
	"env": {
		"ENABLE_TOOL_SEARCH": "1",
		"CLAUDE_ENABLE_STREAM_WATCHDOG": "1",
		"CLAUDE_STREAM_IDLE_TIMEOUT_MS": "900000",
		"CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
		"CLAUDE_CODE_DISABLE_FAST_MODE": "1",
		"CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
		"CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
		"CLAUDE_CODE_NO_FLICKER": "1"
	},
	"effortLevel": "high",
	"skillListingBudgetFraction": 0.08,
	"autoUpdatesChannel": "latest",
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "pgrep -x ollama > /dev/null || nohup ollama serve > /dev/null 2>&1 & for i in $(seq 1 16); do ollama list >/dev/null 2>&1 && break; sleep 0.5; done; exit 0",
						"timeout": 15,
						"statusMessage": "Starting ollama..."
					},
					{
						"type": "command",
						"command": "command -v grepai >/dev/null 2>&1 && { grepai status >/dev/null 2>&1 || grepai init --yes >/dev/null 2>&1; grep -qsx '.grepai/' .gitignore 2>/dev/null || echo '.grepai/' >> .gitignore; grepai watch --background >/dev/null 2>&1; }; exit 0",
						"timeout": 20,
						"statusMessage": "Starting grepai..."
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/ensure-claudeignore.sh",
						"timeout": 5,
						"statusMessage": "Ensuring .claudeignore..."
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/repo-init.sh",
						"timeout": 15,
						"statusMessage": "Checking Vite+ repo state..."
					},
					{
						"type": "command",
						"command": "command -v serena-hooks >/dev/null 2>&1 && serena-hooks activate --client=claude-code; exit 0",
						"timeout": 15,
						"statusMessage": "Activating Serena project..."
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "command -v serena-hooks >/dev/null 2>&1 && serena-hooks cleanup --client=claude-code; exit 0",
						"timeout": 10
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/block-no-verify.sh",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "Read|Grep|Glob",
				"hooks": [
					{
						"type": "command",
						"command": "command -v serena-hooks >/dev/null 2>&1 && serena-hooks remind --client=claude-code; exit 0",
						"timeout": 10
					}
				]
			},
			{
				"matcher": "mcp__serena__*",
				"hooks": [
					{
						"type": "command",
						"command": "command -v serena-hooks >/dev/null 2>&1 && serena-hooks auto-approve --client=claude-code; exit 0",
						"timeout": 10
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "rtk hook claude"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/quality-check.sh",
						"timeout": 20,
						"statusMessage": "Formatting & linting..."
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/typecheck.sh",
						"timeout": 40,
						"async": true,
						"statusMessage": "Type-checking project..."
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/check-as-any.sh",
						"timeout": 5
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/run-tests.sh",
						"timeout": 30,
						"async": true
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/impeccable-check.sh",
						"if": "Edit(*.html)|Edit(*.css)|Edit(*.jsx)|Edit(*.tsx)|Edit(*.vue)|Edit(*.svelte)|Edit(*.astro)|Write(*.html)|Write(*.css)|Write(*.jsx)|Write(*.tsx)|Write(*.vue)|Write(*.svelte)|Write(*.astro)",
						"timeout": 15,
						"async": true,
						"statusMessage": "Checking for UI anti-patterns..."
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/stop-quality-check.sh",
						"timeout": 60,
						"statusMessage": "Verifying task quality..."
					},
					{
						"type": "command",
						"command": "command -v grepai >/dev/null 2>&1 && grepai watch --stop >/dev/null 2>&1; exit 0",
						"timeout": 10,
						"statusMessage": "Stopping grepai watcher..."
					}
				]
			}
		]
	}
}
