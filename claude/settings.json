{
	"enabledPlugins": {
		"chrome-devtools-mcp@claude-plugins-official": true
	},
	"permissions": {
		"defaultMode": "default",
		"allow": [
			"Read",
			"Edit",
			"Write",
			"Glob",
			"Grep",
			"Bash(*)",
			"mcp__claude_ai_Context7",
			"mcp__claude_ai_Figma",
			"mcp__claude_ai_Linear",
			"mcp__gh_grep",
			"mcp__exa",
			"mcp__plugin_chrome-devtools-mcp_chrome-devtools"
		],
		"deny": [
			"Bash(rm -rf:*)",
			"Bash(rm -r:*)",
			"Bash(rm -f:*)",
			"Bash(sudo:*)",
			"Bash(su :*)",
			"Bash(doas :*)",
			"Bash(chmod 777:*)",
			"Bash(git push --force:*)",
			"Bash(git push -f:*)",
			"Bash(git push --force-with-lease:*)",
			"Bash(git reset --hard:*)",
			"Bash(curl * | sh:*)",
			"Bash(curl * | bash:*)",
			"Bash(curl * | fish:*)",
			"Bash(curl * | zsh:*)",
			"Bash(wget * | sh:*)",
			"Bash(wget * | bash:*)",
			"Bash(wget * | fish:*)",
			"Agent(Explore)"
		]
	},
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"enableAllProjectMcpServers": true,
	"statusLine": {
		"type": "command",
		"command": "~/.claude/statusline.sh",
		"padding": 0
	},
	"autoConnectIde": true,
	"env": {
		"CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
		"CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
		"CLAUDE_CODE_AUTO_COMPACT_WINDOW": "280000",
		"CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
		"ENABLE_TOOL_SEARCH": "1",
		"CLAUDE_ENABLE_STREAM_WATCHDOG": "1",
		"CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
		"CLAUDE_CODE_DISABLE_FAST_MODE": "1",
		"CLAUDE_CODE_NO_FLICKER": "1",
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
	},
	"effortLevel": "high",
	"showThinkingSummaries": true,
	"autoUpdatesChannel": "latest",
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "pgrep -x ollama > /dev/null || nohup ollama serve > /dev/null 2>&1 &",
						"timeout": 10,
						"statusMessage": "Starting ollama..."
					},
					{
						"type": "command",
						"command": "command -v grepai >/dev/null 2>&1 && { grepai status >/dev/null 2>&1 || grepai init --yes >/dev/null 2>&1; grep -qsx '.grepai/' .gitignore 2>/dev/null || echo '.grepai/' >> .gitignore; grepai watch --background >/dev/null 2>&1; }; exit 0",
						"timeout": 20,
						"statusMessage": "Starting grepai..."
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/ensure-claudeignore.sh",
						"timeout": 5,
						"statusMessage": "Ensuring .claudeignore..."
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/block-no-verify.sh",
						"timeout": 5
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/auto-format.sh",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/typecheck.sh",
						"timeout": 30
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/run-tests.sh",
						"timeout": 30,
						"async": true
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/impeccable-check.sh",
						"if": "Edit(*.html)|Edit(*.css)|Edit(*.jsx)|Edit(*.tsx)|Edit(*.vue)|Edit(*.svelte)|Edit(*.astro)|Write(*.html)|Write(*.css)|Write(*.jsx)|Write(*.tsx)|Write(*.vue)|Write(*.svelte)|Write(*.astro)",
						"timeout": 15,
						"async": true,
						"statusMessage": "Checking for UI anti-patterns..."
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/stop-quality-check.sh",
						"timeout": 30,
						"statusMessage": "Verifying task quality..."
					},
					{
						"type": "command",
						"command": "command -v grepai >/dev/null 2>&1 && grepai watch --stop >/dev/null 2>&1; exit 0",
						"timeout": 10,
						"statusMessage": "Stopping grepai watcher..."
					}
				]
			}
		],
		"TaskCreated": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/task-created.sh",
						"timeout": 5,
						"statusMessage": "Validating task..."
					}
				]
			}
		],
		"TeammateIdle": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/teammate-idle.sh",
						"timeout": 10,
						"statusMessage": "Checking idle state..."
					}
				]
			}
		]
	}
}
