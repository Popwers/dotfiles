{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(diff:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(pgrep:*)",
      "Bash(pkill:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(brew:*)",
      "Bash(grepai:*)",
      "Bash(ollama:*)",
      "Bash(gh:*)",
      "Bash(fish:*)",
      "Bash(bash:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Bash(test:*)",
      "Bash(nohup:*)",
      "mcp__claude_ai_Context7",
      "mcp__claude_ai_Figma",
      "mcp__claude_ai_Linear"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enableAllProjectMcpServers": true,
  "model": "opus[1m]",
  "language": "Français",
  "fastMode": true,
  "effortLevel": "high",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pgrep -x ollama > /dev/null || nohup ollama serve > /dev/null 2>&1 &",
            "timeout": 10,
            "statusMessage": "Starting ollama..."
          },
          {
            "type": "command",
            "command": "grepai watch --background > /dev/null 2>&1 || true",
            "timeout": 15,
            "statusMessage": "Starting grepai watcher..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "grepai watch --stop > /dev/null 2>&1 || true",
            "timeout": 10,
            "statusMessage": "Stopping grepai watcher..."
          }
        ]
      }
    ]
  }
}
